# Copy to .env and fill in. Never commit the real .env.

# Your LiteLLM proxy base URL (the Vertex gateway).
LITELLM_BASE_URL=https://offeringschat.isha.in

# Your API key (starts with sk-...). Optional here:
# you can also paste it in the app's Settings panel instead.
LITELLM_API_KEY=

# Local port for the app (optional).
PORT=8000
